<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- VÙNG HIỂN THỊ (Điều chỉnh 32% chiều cao và thêm paddingTop để không bị khuất) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/displayArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.32"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="History"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#A5A5A5" />

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:gravity="end"
            android:textColor="#A5A5A5"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@id/tvResult"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnHistory"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="125 x 2" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:fontFamily="sans-serif-light"
            android:gravity="end"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="44sp"
            app:autoSizeMaxTextSize="44sp"
            app:autoSizeMinTextSize="24sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvExpression" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CỤM PHÍM KHOA HỌC (38% Chiều rộng) -->
    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flowScientific"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        app:flow_horizontalGap="8dp"
        app:flow_verticalGap="8dp"
        app:flow_maxElementsWrap="3"
        app:flow_wrapMode="chain"
        app:constraint_referenced_ids="btnSin,btnCos,btnTan,btnSqrt,btnSquare,btnPi,btnLog,btnExp,btnPow"
        app:layout_constraintTop_toBottomOf="@id/displayArea"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/flow"
        app:layout_constraintHorizontal_weight="3.8" />

    <!-- CỤM PHÍM CƠ BẢN (62% Chiều rộng) -->
    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        app:flow_horizontalGap="8dp"
        app:flow_verticalGap="8dp"
        app:flow_maxElementsWrap="6"
        app:flow_wrapMode="chain"
        app:constraint_referenced_ids="btn7,btn8,btn9,btnClear,btnBackspace,btnDivide,btn4,btn5,btn6,btnMultiply,btnSubtract,btnAdd,btn1,btn2,btn3,btn0,btnDot,btnEqual"
        app:layout_constraintTop_toBottomOf="@id/displayArea"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/flowScientific"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="6.2" />

    <!-- PHÍM KHOA HỌC -->
    <Button android:id="@+id/btnSin" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="sin" android:textSize="14sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnCos" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="cos" android:textSize="14sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnTan" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="tan" android:textSize="14sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnSqrt" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="√" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnSquare" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="x²" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnPi" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="π" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnLog" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="log" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnExp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="exp" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnPow" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="^" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#222222" app:cornerRadius="50dp" />

    <!-- PHÍM SỐ -->
    <Button android:id="@+id/btn0" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="0" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn1" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="1" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn2" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="2" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn3" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="3" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn4" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="4" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn5" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="5" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn6" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="6" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn7" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="7" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn8" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="8" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btn9" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="9" android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnDot" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="." android:textSize="22sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" app:cornerRadius="50dp" />

    <!-- PHÍM PHÉP TÍNH -->
    <Button android:id="@+id/btnDivide" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="/" android:textSize="24sp" android:textColor="#FFFFFF" android:backgroundTint="#FF9F0A" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnMultiply" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="x" android:textSize="24sp" android:textColor="#FFFFFF" android:backgroundTint="#FF9F0A" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnSubtract" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="-" android:textSize="28sp" android:textColor="#FFFFFF" android:backgroundTint="#FF9F0A" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnAdd" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="+" android:textSize="24sp" android:textColor="#FFFFFF" android:backgroundTint="#FF9F0A" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnEqual" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="=" android:textSize="24sp" android:textColor="#FFFFFF" android:backgroundTint="#FF9F0A" app:cornerRadius="50dp" />

    <!-- PHÍM CHỨC NĂNG -->
    <Button android:id="@+id/btnClear" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="AC" android:textSize="18sp" android:textColor="#000000" android:backgroundTint="#A5A5A5" app:cornerRadius="50dp" />
    <Button android:id="@+id/btnBackspace" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:layout_width="0dp" android:layout_height="0dp" android:text="DEL" android:textSize="14sp" android:textColor="#000000" android:backgroundTint="#A5A5A5" app:cornerRadius="50dp" />

</androidx.constraintlayout.widget.ConstraintLayout>